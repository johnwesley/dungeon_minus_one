# Deployment secrets
# Copy to .env.deploy and fill in real values:
#   cp .env.deploy.example .env.deploy

# DigitalOcean API token
DO_TOKEN=dop_v1_xxx

# DigitalOcean Spaces (for asset publishing)
SPACES_ACCESS_KEY=do_access_key
SPACES_SECRET_KEY=do_secret_key
# AWS-style aliases also work
# AWS_ACCESS_KEY_ID=do_access_key
# AWS_SECRET_ACCESS_KEY=do_secret_key

# Optional: override CDN domains
# ASSET_CDN_DOMAIN=assets-staging.dungeonminusone.com
# ASSET_CDN_DOMAIN_STAGING=assets-staging.dungeonminusone.com
# ASSET_CDN_DOMAIN_PROD=assets.dungeonminusone.com

# DigitalOcean Spaces credentials (Full Access, for CORS configuration)
# Generate at: https://cloud.digitalocean.com/account/api/spaces
SPACES_ACCESS_ID=
SPACES_SECRET_KEY=

# DNSimple API (for staging DNS management)
DNSIMPLE_TOKEN=your_dnsimple_token
DNSIMPLE_ACCOUNT_ID=your_account_id
